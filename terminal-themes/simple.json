{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "#BCBCBC",
          "style": "plain",
          "template": "took {{ .FormattedMs }} ",
          "type": "executiontime",
          "properties": {
            "threshold": 500
          }
        }
      ],
      "type": "rprompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#77E4F7",
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path",
          "properties": {
            "style": "full"
          }
        },
        {
          "foreground": "#FFE700",
          "style": "plain",
          "template": "{{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }}*{{ end }}{{ if gt .Behind 0 }} <cyan>\u21e3</>{{ end }}{{ if gt .Ahead 0 }} <cyan>\u21e1</>{{ end }} ",
          "type": "git",
          "properties": {
            "branch_icon": "",
            "commit_icon": "@",
            "fetch_status": true,
            "timeout": 300
          }
        },
        {
          "foreground": "#43D426",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FF0000{{ end }}"
          ],
          "style": "plain",
          "template": "\u276f ",
          "type": "status",
          "properties": {
            "always_enabled": true
          }
        }
      ],
      "type": "prompt"
    }
  ],
  "tooltips": [
    {
      "foreground": "#FF9900",
      "style": "plain",
      "template": "\u2601 {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} ",
      "type": "aws",
      "tips": ["aws", "isengardcli"]
    },
    {
      "foreground": "#326CE5",
      "style": "plain",
      "template": "\u2388 {{ .Context }}{{ if .Namespace }}::{{ .Namespace }}{{ end }} ",
      "type": "kubectl",
      "tips": ["kubectl", "k", "helm"],
      "properties": {
        "parse_kubeconfig": true
      }
    }
  ],
  "transient_prompt": {
    "foreground_templates": [
      "{{ if gt .Code 0 }}#FF0000{{ end }}",
      "{{ if eq .Code 0 }}#43D426{{ end }}"
    ],
    "template": "\u276f "
  },
  "secondary_prompt": {
    "template": "<#FFE700>\u276f\u276f </>"
  },
  "version": 4
}
